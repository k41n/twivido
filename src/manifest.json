{
  "manifest_version": 3,
  "name": "Twivido — X (Twitter) Video & Image Downloader",
  "version": "1.1.2",
  "description": "Download videos, GIFs and images from X (Twitter) in one click — right from your feed. Highest quality, with audio.",
  "homepage_url": "https://github.com/k41n/twivido",
  "permissions": ["downloads"],
  "host_permissions": [
    "*://*.twimg.com/*",
    "*://x.com/*",
    "*://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twivido — download X video"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
